---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><link rel="icon" href="/favicon.svg"/><title>Sign Up - BidProperty</title><meta name="description" content="Create your BidProperty account and start bidding on properties."/><RequiredB12HeadScripts/></head><body class="bg-background text-foreground"><Header currentPage="account"/><main><section class="min-h-screen flex items-center justify-center px-4 py-12"><div class="w-full max-w-md"><div class="text-center mb-12"><h1 class="text-4xl font-bold mb-3">Create Account</h1><p class="text-muted-foreground">Get started with BidProperty and place your first bid.</p></div><form class="bg-card border border-border p-8 rounded-lg space-y-5"><div class="grid grid-cols-2 gap-4"><div><label class="block text-sm font-semibold mb-2">First Name *</label><input type="text" placeholder="John" required class="w-full px-4 py-2 border border-border rounded bg-background"/></div><div><label class="block text-sm font-semibold mb-2">Last Name *</label><input type="text" placeholder="Doe" required class="w-full px-4 py-2 border border-border rounded bg-background"/></div></div><div><label class="block text-sm font-semibold mb-2">Email Address *</label><input type="email" placeholder="you@example.com" required class="w-full px-4 py-2 border border-border rounded bg-background"/></div><div><label class="block text-sm font-semibold mb-2">Password *</label><input type="password" placeholder="••••••••" required class="w-full px-4 py-2 border border-border rounded bg-background"/><p class="text-xs text-muted-foreground mt-2">At least 8 characters with uppercase, lowercase, and numbers</p></div><div><label class="block text-sm font-semibold mb-2">Confirm Password *</label><input type="password" placeholder="••••••••" required class="w-full px-4 py-2 border border-border rounded bg-background"/></div><label class="flex items-start gap-3 text-sm text-muted-foreground"><input type="checkbox" required class="mt-1 w-4 h-4 rounded border-border"/>I agree to the Terms of Service and Privacy Policy *</label><button type="submit" class="w-full py-3 bg-primary text-primary-foreground rounded font-semibold hover:opacity-90">Create Account</button><div class="grid grid-cols-2 gap-4"><button type="button" class="py-2 border border-border rounded hover:bg-muted font-semibold text-sm">Google</button><button type="button" class="py-2 border border-border rounded hover:bg-muted font-semibold text-sm">GitHub</button></div></form><div class="mt-6 text-center"><p class="text-muted-foreground">Already have an account? <a href="/sign-in" class="text-primary hover:underline font-semibold">Sign in here</a></p></div></div></section></main><Footer/><RequiredB12FooterScripts/></body></html>
