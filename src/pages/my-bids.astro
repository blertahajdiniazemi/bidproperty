---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
const userBids = [
  { id: 1, propertyTitle: "Historic Colonial Estate", location: "Boston, MA", yourBid: 470000, highestBid: 485000, status: "outbid", timeLeft: "2 days", bidsPlaced: 3 },
  { id: 2, propertyTitle: "Modern Downtown Condo", location: "New York, NY", yourBid: 800000, highestBid: 810000, status: "outbid", timeLeft: "5 days", bidsPlaced: 2 },
  { id: 3, propertyTitle: "Luxury Waterfront Villa", location: "Miami, FL", yourBid: 1350000, highestBid: 1350000, status: "leading", timeLeft: "1 day", bidsPlaced: 5 },
  { id: 6, propertyTitle: "Historic Downtown Loft", location: "San Francisco, CA", yourBid: 945000, highestBid: 950000, status: "outbid", timeLeft: "4 days", bidsPlaced: 4 }
];
const pastBids = [
  { id: 4, propertyTitle: "Modern Townhouse Complex", location: "Seattle, WA", finalBid: 640000, winningBid: 650000, status: "closed", endDate: "2026-05-10" },
  { id: 5, propertyTitle: "Commercial Office Tower", location: "Chicago, IL", finalBid: 5300000, winningBid: 5500000, status: "closed", endDate: "2026-04-28" }
];
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><link rel="icon" href="/favicon.svg"/><title>My Bids - BidProperty</title><meta name="description" content="View and manage your active bids on BidProperty."/><RequiredB12HeadScripts/></head><body class="bg-background text-foreground"><Header currentPage="my-bids"/><main><section class="py-12 px-4 border-b border-border bg-muted"><div class="max-w-6xl mx-auto"><h1 class="text-4xl font-bold mb-4">My Bids</h1><p class="text-lg text-muted-foreground">Track your active bids and bidding history</p></div></section><section class="py-12 px-4 text-center bg-primary/5 border-b border-primary/20"><div class="max-w-2xl mx-auto"><h2 class="text-2xl font-bold mb-4">Sign in to view your bids</h2><p class="text-muted-foreground mb-6">Create an account or sign in to track and manage your property bids.</p><div class="flex gap-4 justify-center flex-wrap"><a href="/sign-in" class="px-6 py-3 bg-primary text-primary-foreground rounded font-semibold hover:opacity-90">Sign In</a><a href="/sign-up" class="px-6 py-3 border-2 border-primary text-primary rounded font-semibold hover:bg-muted">Create Account</a></div></div></section><section class="py-16 px-4"><div class="max-w-6xl mx-auto"><h2 class="text-3xl font-bold mb-8">Active Bids</h2><div class="space-y-4">{userBids.map(bid=><div class="border border-border rounded-lg p-6 bg-card hover:shadow-lg transition-shadow"><div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-center"><div><h3 class="font-semibold text-lg">{bid.propertyTitle}</h3><p class="text-sm text-muted-foreground">{bid.location}</p></div><div class="text-center"><p class="text-xs text-muted-foreground uppercase font-semibold mb-1">Your Bid</p><p class="text-lg font-bold">${(bid.yourBid/1000).toFixed(0)}K</p></div><div class="text-center"><p class="text-xs text-muted-foreground uppercase font-semibold mb-1">Highest</p><p class="text-lg font-bold text-primary">${(bid.highestBid/1000).toFixed(0)}K</p></div><div class="flex flex-col gap-2"><span class={`inline-block px-3 py-1 rounded text-sm font-semibold ${bid.status==='leading'?'bg-green-100 text-green-700':'bg-orange-100 text-orange-700'}`}>{bid.status==='leading'?'Winning':'Outbid'}</span><p class="text-sm text-muted-foreground">{bid.timeLeft} left</p></div></div><div class="mt-4 pt-4 border-t border-border flex justify-between items-center"><span class="text-sm text-muted-foreground">{bid.bidsPlaced} bids placed</span><a href={`/properties/${bid.id}`} class="text-primary hover:underline font-semibold text-sm">View Property →</a></div></div>)}</div></div></section><section class="py-16 px-4 bg-muted"><div class="max-w-6xl mx-auto"><h2 class="text-3xl font-bold mb-8">Bid History</h2><div class="bg-card border border-border rounded-lg overflow-x-auto"><table class="w-full"><thead class="bg-muted border-b border-border"><tr><th class="px-6 py-4 text-left text-sm font-semibold">Property</th><th class="px-6 py-4 text-left text-sm font-semibold">Your Final Bid</th><th class="px-6 py-4 text-left text-sm font-semibold">Winning Bid</th><th class="px-6 py-4 text-left text-sm font-semibold">Result</th><th class="px-6 py-4 text-left text-sm font-semibold">Date Ended</th></tr></thead><tbody>{pastBids.map(bid=><tr class="border-b border-border hover:bg-muted/50 last:border-b-0"><td class="px-6 py-4"><p class="font-semibold">{bid.propertyTitle}</p><p class="text-sm text-muted-foreground">{bid.location}</p></td><td class="px-6 py-4 font-semibold">${(bid.finalBid/1000).toFixed(0)}K</td><td class="px-6 py-4 font-bold text-primary">${(bid.winningBid/1000).toFixed(0)}K</td><td class="px-6 py-4"><span class="px-3 py-1 rounded text-sm font-semibold bg-gray-100 text-gray-700">Closed</span></td><td class="px-6 py-4 text-muted-foreground">{bid.endDate}</td></tr>)}</tbody></table></div></div></section></main><Footer/><RequiredB12FooterScripts/></body></html>
