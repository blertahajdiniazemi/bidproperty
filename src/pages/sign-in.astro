---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><link rel="icon" href="/favicon.svg"/><title>Sign In - BidProperty</title><meta name="description" content="Sign in to your BidProperty account to place bids."/><RequiredB12HeadScripts/></head><body class="bg-background text-foreground"><Header currentPage="account"/><main><section class="min-h-screen flex items-center justify-center px-4 py-12"><div class="w-full max-w-md"><div class="text-center mb-12"><h1 class="text-4xl font-bold mb-3">Sign In</h1><p class="text-muted-foreground">Welcome back! Sign in to your BidProperty account.</p></div><form class="bg-card border border-border p-8 rounded-lg space-y-6"><div><label class="block text-sm font-semibold mb-2">Email Address</label><input type="email" placeholder="you@example.com" required class="w-full px-4 py-3 border border-border rounded bg-background"/></div><div><label class="block text-sm font-semibold mb-2">Password</label><input type="password" placeholder="••••••••" required class="w-full px-4 py-3 border border-border rounded bg-background"/></div><div class="flex items-center justify-between text-sm"><label class="flex items-center gap-2"><input type="checkbox" class="w-4 h-4 rounded border-border"/><span class="text-muted-foreground">Remember me</span></label><a href="#" class="text-primary hover:underline font-semibold">Forgot password?</a></div><button type="submit" class="w-full py-3 bg-primary text-primary-foreground rounded font-semibold hover:opacity-90">Sign In</button><div class="grid grid-cols-2 gap-4"><button type="button" class="py-2 border border-border rounded hover:bg-muted font-semibold text-sm">Google</button><button type="button" class="py-2 border border-border rounded hover:bg-muted font-semibold text-sm">GitHub</button></div></form><div class="mt-6 text-center"><p class="text-muted-foreground">Don't have an account? <a href="/sign-up" class="text-primary hover:underline font-semibold">Sign up here</a></p></div></div></section></main><Footer/><RequiredB12FooterScripts/></body></html>
