---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
import { allProperties } from '../lib/properties';
const featured = allProperties.slice(0,3);
---
<html lang="en">
  <head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><link rel="icon" type="image/svg+xml" href="/favicon.svg"/><meta name="generator" content={Astro.generator}/><title>BidProperty - Secure Property Bidding Platform</title><meta name="description" content="Secure property bidding platform built on modern infrastructure."/><RequiredB12HeadScripts/></head>
  <body class="bg-background text-foreground"><Header currentPage="home"/><main>
    <section id="hero" class="pt-20 pb-20 px-4"><div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"><div><h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-tight">Secure property bidding, built on modern infrastructure.</h1><p class="text-lg text-muted-foreground mb-8 leading-relaxed">BidProperty uses private repositories, Vercel hosting, Supabase-ready data workflows, and secure domain management. Browse properties and place secure bids with confidence.</p><div class="flex gap-4 flex-wrap"><a href="/properties" class="px-6 py-3 bg-primary text-primary-foreground rounded font-semibold hover:opacity-90">Browse Properties</a><a href="/sign-up" class="px-6 py-3 border-2 border-primary text-primary rounded font-semibold hover:bg-muted">Sign Up to Bid</a></div></div><div class="hidden lg:block"><img src="https://cdn.b12.io/client_media/MMT7mwJl/ff41f773-4fe9-11f1-a78f-0242ac110002-9hLp7IN7sq-3TMp1tITDD.jpg" alt="Property bidding dashboard" class="rounded-lg shadow-lg w-full"/></div></div></section>
    <section id="how-it-works" class="py-20 px-4 bg-muted"><div class="max-w-6xl mx-auto"><h2 class="text-4xl font-bold text-center mb-16">How It Works</h2><div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">{['Browse Properties','Place Your Bid','Win & Complete'].map((title,i)=><div class="bg-card p-8 rounded-lg border border-border"><div class="w-12 h-12 bg-primary text-primary-foreground rounded-full flex items-center justify-center text-xl font-bold mb-4">{i+1}</div><h3 class="text-xl font-semibold mb-3">{title}</h3><p class="text-muted-foreground">Explore available properties, create an account, and track bidding activity in a secure platform.</p></div>)}</div><div class="bg-card p-12 rounded-lg border border-border text-center"><h3 class="text-2xl font-semibold mb-4">Built for Security & Trust</h3><div class="grid grid-cols-1 md:grid-cols-4 gap-6 text-sm">{['Private GitHub repos','Vercel hosting','Supabase database','Cloudflare Registrar'].map((item)=><div><div class="font-semibold text-primary mb-2">{item}</div><p class="text-muted-foreground">Modern infrastructure</p></div>)}</div></div></div></section>
    <section class="py-20 px-4"><div class="max-w-6xl mx-auto"><h2 class="text-4xl font-bold mb-4">Featured Properties</h2><p class="text-lg text-muted-foreground mb-12">Explore some of our most sought-after properties available for bidding.</p><div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">{featured.map(property=><a href={`/properties/${property.id}`} class="group rounded-lg border border-border overflow-hidden hover:shadow-lg transition-shadow"><div class="aspect-video bg-muted overflow-hidden"><img src={property.image} alt={property.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"/></div><div class="p-6 bg-card"><h3 class="font-semibold text-lg mb-2">{property.title}</h3><p class="text-sm text-muted-foreground mb-4">{property.location}</p><div class="flex justify-between items-center"><span class="text-lg font-bold text-primary">${(property.minPrice/1000).toFixed(0)}K - ${(property.maxPrice/1000).toFixed(0)}K</span><span class="text-sm bg-muted px-3 py-1 rounded text-muted-foreground">{property.bidsCount} bids</span></div></div></a>)}</div><div class="text-center mt-12"><a href="/properties" class="px-6 py-3 border-2 border-primary text-primary rounded font-semibold hover:bg-muted">View All Properties</a></div></div></section>
  </main><Footer/><RequiredB12FooterScripts/></body>
</html>
