---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RequiredB12HeadScripts from '../../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../../components/RequiredB12FooterScripts.astro';
import { allProperties, type Property } from '../../lib/properties';
export function getStaticPaths() { return allProperties.map((prop) => ({ params: { id: prop.id.toString() }, props: { property: prop } })); }
interface Props { property: Property; }
const { property } = Astro.props as Props;
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><link rel="icon" href="/favicon.svg"/><title>{property.title} - BidProperty</title><meta name="description" content={property.description}/><RequiredB12HeadScripts/></head><body class="bg-background text-foreground"><Header currentPage="properties"/><main><section class="py-8 px-4 border-b border-border"><div class="max-w-6xl mx-auto"><a href="/properties" class="text-primary hover:underline text-sm mb-4 inline-block">← Back to Properties</a><h1 class="text-4xl font-bold mb-2">{property.title}</h1><p class="text-lg text-muted-foreground">{property.location}</p></div></section><section class="py-12 px-4"><div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12"><div class="lg:col-span-2"><img src={property.image} alt={property.title} class="w-full rounded-lg border border-border mb-8"/><div class="bg-card p-8 rounded-lg border border-border mb-8"><h2 class="text-2xl font-bold mb-4">About This Property</h2><p class="text-muted-foreground leading-relaxed mb-6">{property.description}</p><div class="grid grid-cols-2 md:grid-cols-4 gap-6">{property.features.map(feature=><div class="flex items-start gap-3"><span class="text-primary text-xl leading-none">✓</span><span class="text-sm font-medium">{feature}</span></div>)}</div></div><div class="bg-card p-8 rounded-lg border border-border"><h2 class="text-2xl font-bold mb-6">Recent Bids</h2><div class="space-y-4">{property.recentBids.map(bid=><div class="flex justify-between items-center pb-4 border-b border-border last:border-b-0"><div><p class="font-semibold">{bid.bidder}</p><p class="text-sm text-muted-foreground">{bid.time}</p></div><p class="font-bold text-lg text-primary">${(bid.amount/1000).toFixed(0)}K</p></div>)}</div></div></div><aside><div class="bg-primary/5 p-8 rounded-lg border-2 border-primary sticky top-24"><h3 class="text-sm font-semibold text-primary mb-6 uppercase">Bidding Details</h3><div class="space-y-6"><div><p class="text-xs text-muted-foreground uppercase font-semibold mb-1">Highest Bid</p><p class="text-3xl font-bold text-primary">${(property.highestBid/1000).toFixed(0)}K</p><p class="text-sm text-muted-foreground mt-2">by {property.highestBidder}</p></div><div><p class="text-xs text-muted-foreground uppercase font-semibold mb-1">Minimum Increment</p><p class="text-xl font-semibold">${(property.minimumIncrement/1000).toFixed(1)}K</p></div><div><p class="text-xs text-muted-foreground uppercase font-semibold mb-1">Time Remaining</p><p class="text-xl font-semibold">{property.timeRemaining}</p></div><div><p class="text-xs text-muted-foreground uppercase font-semibold mb-1">Number of Bids</p><p class="text-xl font-semibold">{property.bidsCount} bids</p></div><div class="pt-2 border-t border-primary/20"><p class="text-xs text-muted-foreground uppercase font-semibold mb-3">Your Bid</p><input type="number" placeholder={`Min: $${((property.highestBid+property.minimumIncrement)/1000).toFixed(0)}K`} class="w-full px-4 py-2 border border-border rounded bg-background"/><a href="/sign-in" class="w-full mt-4 block text-center px-6 py-3 bg-primary text-primary-foreground rounded font-semibold hover:opacity-90">Sign In to Bid</a></div><div class="text-xs text-muted-foreground bg-muted p-3 rounded"><p class="font-semibold mb-2">Price Range</p><p>${(property.minPrice/1000).toFixed(0)}K - ${(property.maxPrice/1000).toFixed(0)}K</p></div></div></div></aside></div></section></main><Footer/><RequiredB12FooterScripts/></body></html>
