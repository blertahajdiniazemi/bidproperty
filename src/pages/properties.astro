---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
import { allProperties as properties } from '../lib/properties';
---
<html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width"/><link rel="icon" href="/favicon.svg"/><title>Browse Properties - BidProperty</title><meta name="description" content="Browse available properties for bidding on BidProperty."/><RequiredB12HeadScripts/></head><body class="bg-background text-foreground"><Header currentPage="properties"/><main><section class="py-12 px-4 border-b border-border bg-muted"><div class="max-w-6xl mx-auto"><h1 class="text-4xl font-bold mb-4">Properties for Bidding</h1><p class="text-lg text-muted-foreground">Explore available properties. Browse, bid, and win your next property.</p></div></section><section class="py-6 px-4 border-b border-border sticky top-16 bg-card z-40"><div class="max-w-6xl mx-auto flex flex-wrap gap-4 items-center"><input type="text" placeholder="Search by location..." class="flex-1 min-w-[200px] px-4 py-2 border border-border rounded bg-background"/><select class="px-4 py-2 border border-border rounded bg-background"><option>All Price Ranges</option><option>Under $500K</option><option>$500K - $1M</option><option>$1M+</option></select><select class="px-4 py-2 border border-border rounded bg-background"><option>All Types</option><option>Residential</option><option>Commercial</option><option>Luxury</option></select></div></section><section class="py-16 px-4"><div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">{properties.map(property=><a href={`/properties/${property.id}`} class="group rounded-lg border border-border overflow-hidden hover:shadow-lg transition-shadow bg-card"><div class="aspect-video bg-muted overflow-hidden"><img src={property.image} alt={property.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"/></div><div class="p-6"><h3 class="font-semibold text-lg mb-1">{property.title}</h3><p class="text-sm text-muted-foreground mb-4">{property.location}</p><div class="space-y-3 mb-4 text-sm"><div class="flex justify-between"><span class="text-muted-foreground">Price Range:</span><span class="font-semibold">${(property.minPrice/1000).toFixed(0)}K - ${(property.maxPrice/1000).toFixed(0)}K</span></div><div class="flex justify-between"><span class="text-muted-foreground">Highest Bid:</span><span class="font-semibold text-primary">${(property.highestBid/1000).toFixed(0)}K</span></div><div class="flex justify-between"><span class="text-muted-foreground">Time Left:</span><span class="font-semibold">{property.timeRemaining}</span></div></div><div class="border-t border-border pt-4 flex justify-between items-center text-sm"><span class="text-muted-foreground">{property.bidsCount} bids</span><span class="px-3 py-1 bg-primary/10 text-primary rounded font-semibold">View Details</span></div></div></a>)}</div></section></main><Footer/><RequiredB12FooterScripts/></body></html>
