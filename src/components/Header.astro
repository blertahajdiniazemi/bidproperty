---
interface Props { currentPage?: string }
const { currentPage = 'home' } = Astro.props as Props;
const nav = [
  { href: '/', key: 'home', label: 'Home' },
  { href: '/properties', key: 'properties', label: 'Properties' },
  { href: '/my-bids', key: 'my-bids', label: 'My Bids' },
  { href: '/account', key: 'account', label: 'Account' },
];
---
<header class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-foreground">
      <span class="flex size-9 items-center justify-center rounded-lg bg-primary text-primary-foreground">BP</span>
      <span>BidProperty</span>
    </a>
    <nav class="hidden items-center gap-6 md:flex">
      {nav.map(item => (
        <a href={item.href} class:list={["text-sm font-medium transition-colors hover:text-primary", currentPage === item.key ? "text-primary" : "text-muted-foreground"]}>{item.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href="/sign-in" class="hidden text-sm font-semibold text-muted-foreground hover:text-primary sm:inline">Sign In</a>
      <a href="/sign-up" class="rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:opacity-90">Sign Up</a>
    </div>
  </div>
</header>
